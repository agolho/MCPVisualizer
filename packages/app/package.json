{
  "name": "@mcpviz/app",
  "version": "0.1.0",
  "private": true,
  "description": "MCPVisualizer desktop app",
  "author": {
    "name": "Yusuf Bektas",
    "email": "yusuf.bektas@dreidel.mx"
  },
  "main": "dist/main.js",
  "scripts": {
    "build:main": "tsc -p .",
    "build:viz": "npm run build -w @mcpviz/viz",
    "build:ingester": "npm run build -w @mcpviz/ingester",
    "build": "npm run build:ingester && npm run build:viz && npm run build:main",
    "dev:main": "tsc -p . --watch",
    "dev:electron": "cross-env MCPVIZ_DEV=1 MCPVIZ_VITE_URL=http://localhost:5173 electron dist/main.js",
    "dev": "npm run build:ingester && npm run build:main && concurrently -n viz,electron -c green,cyan \"npm run dev -w @mcpviz/viz\" \"wait-on http://localhost:5173 && npm run dev:electron\"",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "release": "npm run build && electron-builder --publish always"
  },
  "dependencies": {
    "@mcpviz/ingester": "*",
    "@mcpviz/shared": "*",
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.3",
    "wait-on": "^8.0.1"
  }
}
